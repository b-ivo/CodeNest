{
  "version": 2,
  "builds": [
    {
      "src": "server/Server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/Server.js"
    },
    {
      "source": "/(.*)",
      "destination": "client/$1"
    },
    {
      "source": "/(.*)",
      "destination": "client/index.html"
    }
  ]
}
